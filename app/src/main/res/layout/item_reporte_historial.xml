<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_alumno"
    android:elevation="3dp"
    android:padding="14dp"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/txtFechaItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2026-04-12 (Fija)"
        android:textStyle="bold"
        android:textColor="#173548"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/txtAsistenciaItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Asistió"
        android:textSize="12sp"
        android:textColor="#6F655D"
        android:layout_marginTop="3dp" />

    <TextView
        android:id="@+id/txtContenidoItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:text="Notas de la clase..."
        android:textColor="#263746"
        android:textSize="14sp"
        android:lineSpacingExtra="2dp" />

</LinearLayout>