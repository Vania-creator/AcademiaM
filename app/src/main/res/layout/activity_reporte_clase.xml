<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F3F3F3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:background="#173548"
            android:gravity="center_vertical"
            android:padding="20dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Generar Reporte"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />
            <ImageView
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/logo" />
        </LinearLayout>
        <TextView
            android:id="@+id/txtErrorReporte"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:background="@drawable/error_rojo"
            android:gravity="center"
            android:padding="12dp"
            android:text="Completa los campos"
            android:textColor="#B71C1C"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Selecciona la Fecha"
                android:textColor="#111111"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />
            <TextView
                android:id="@+id/btnSeleccionarFecha"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/campo_redondo"
                android:drawableStart="@android:drawable/ic_menu_my_calendar"
                android:drawablePadding="12dp"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:text="Toca para elegir fecha..."
                android:textColor="#222222"
                android:layout_marginBottom="18dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2. Alumno y Clase"
                android:textColor="#111111"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />
            <TextView
                android:id="@+id/btnSeleccionarAlumno"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/campo_redondo"
                android:backgroundTint="#EEEEEE"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:text="Esperando fecha..."
                android:textColor="#888888"
                android:layout_marginBottom="18dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="18dp"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="5dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tipo Detectado"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/txtTipoClaseAuto"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="#E0E0E0"
                        android:gravity="center"
                        android:text="--"
                        android:textColor="#444444"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="5dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Instrumento"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/txtInstrumentoAuto"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="#E0E0E0"
                        android:gravity="center"
                        android:text="--"
                        android:textColor="#444444"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="18dp">

                <CheckBox
                    android:id="@+id/cbAsistio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="El alumno asistió a clase"
                    android:textSize="16sp"
                    android:buttonTint="#173548" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="* Si el alumno NO asistió, no es necesario llenar el cuadro de estudio ni notas."
                    android:textColor="#D32F2F"
                    android:textSize="12sp"
                    android:paddingStart="32dp"
                    android:textStyle="italic" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginBottom="18dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginBottom="18dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿Cuánto estudió en la semana?"
                android:textColor="#111111"
                android:layout_marginBottom="8dp" />
            <EditText
                android:id="@+id/etCuantoEstudio"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/campo_redondo"
                android:hint="Ej. 3 horas, poco, mucho..."
                android:paddingStart="15dp"
                android:textSize="14sp"
                android:layout_marginBottom="18dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Observaciones de la clase"
                android:textColor="#111111"
                android:layout_marginBottom="8dp" />
            <EditText
                android:id="@+id/etNotasClase"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/campo_redondo"
                android:gravity="top"
                android:padding="15dp"
                android:hint="Temas vistos, avances o pendientes..."
                android:textSize="14sp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Insignia de Motivación (Opcional)"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="25dp">
                <ImageView android:id="@+id/imgInsignia1" android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/logo" android:alpha="0.4" android:layout_margin="8dp" android:background="@drawable/circulo_gris" />
                <ImageView android:id="@+id/imgInsignia2" android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/logo" android:alpha="0.4" android:layout_margin="8dp" android:background="@drawable/circulo_gris" />
                <ImageView android:id="@+id/imgInsignia3" android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/logo" android:alpha="0.4" android:layout_margin="8dp" android:background="@drawable/circulo_gris" />
                <ImageView android:id="@+id/imgInsignia4" android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/logo" android:alpha="0.4" android:layout_margin="8dp" android:background="@drawable/circulo_gris" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnRegresarReporte"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/boton_gris"
                    android:text="Cancelar" />
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnIngresarReporte"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1.2"
                    android:background="@drawable/boton_gris"
                    android:backgroundTint="#173548"
                    android:text="Guardar Reporte"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</ScrollView>