<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F3F3F3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="#173548"
            android:gravity="center_vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reporte de Clase"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@drawable/logo"
                android:contentDescription="Logo" />
        </LinearLayout>

        <!-- ERROR -->
        <TextView
            android:id="@+id/txtErrorReporte"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="-12dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/error_rojo"
            android:gravity="center"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:text="Completa los campos"
            android:textColor="#000000"
            android:textSize="22sp"
            android:visibility="gone" />

        <!-- CONTENIDO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alumno"
                android:textColor="#111111"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etAlumno"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/campo_redondo"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#111111"
                android:textColorHint="#777777"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha"
                android:textColor="#111111"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etFecha"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/campo_redondo"
                android:focusable="false"
                android:clickable="true"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#111111"
                android:textColorHint="#777777"
                android:hint="Selecciona una fecha"
                android:layout_marginBottom="18dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="El Alumno Asistio"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:layout_marginEnd="14dp" />

                <CheckBox
                    android:id="@+id/cbAsistio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#D0D0D0"
                android:layout_marginBottom="18dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipo de Clase"
                android:textColor="#111111"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etTipoClase"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/campo_redondo"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#111111"
                android:textColorHint="#777777"
                android:layout_marginBottom="18dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿Cuanto Estudio?"
                android:textColor="#111111"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etCuantoEstudio"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/campo_redondo"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#111111"
                android:textColorHint="#777777"
                android:layout_marginBottom="18dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notas de Clase"
                android:textColor="#111111"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(incidencias, problemas, detalles de relevancia)"
                android:textColor="#888888"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etNotasClase"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/campo_redondo"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#111111"
                android:textColorHint="#777777"
                android:layout_marginBottom="18dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Asignar Gamificacion"
                android:textColor="#111111"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Motivacion para el alumno"
                android:textColor="#888888"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/layoutGamificacion"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/campo_redondo"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:id="@+id/imgInsignia1"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:src="@drawable/logo"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/circulo_gris"
                    android:padding="6dp"
                    android:contentDescription="Insignia 1" />

                <ImageView
                    android:id="@+id/imgInsignia2"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:src="@drawable/logo"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/circulo_gris"
                    android:padding="6dp"
                    android:contentDescription="Insignia 2" />

                <ImageView
                    android:id="@+id/imgInsignia3"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:src="@drawable/logo"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/circulo_gris"
                    android:padding="6dp"
                    android:contentDescription="Insignia 3" />

                <ImageView
                    android:id="@+id/imgInsignia4"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:src="@drawable/logo"
                    android:background="@drawable/circulo_gris"
                    android:padding="6dp"
                    android:contentDescription="Insignia 4" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnRegresarReporte"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/boton_gris"
                    android:backgroundTint="@null"
                    android:text="Regresar"
                    android:textAllCaps="false"
                    android:textColor="#222222" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnIngresarReporte"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/boton_gris"
                    android:backgroundTint="@null"
                    android:text="Ingresar"
                    android:textAllCaps="false"
                    android:textColor="#222222" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>