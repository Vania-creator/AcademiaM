<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_alumno"
    android:backgroundTint="@null"
    android:elevation="3dp"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <TextView
        android:id="@+id/txtStatusItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PENDIENTE"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="#B3261E"
        android:background="@drawable/etiqueta_pendiente"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/txtTituloTareaItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Título de la Tarea"
        android:textStyle="bold"
        android:textColor="#173548"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/txtFechaTareaItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Asignada: 2026-04-12"
        android:textSize="12sp"
        android:textColor="#64748B"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/txtDescTareaItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Descripción detallada de la tarea..."
        android:textColor="#263746"
        android:textSize="14sp"
        android:lineSpacingExtra="2dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnAbrirTareaItem"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/boton_gris"
        android:backgroundTint="#173548"
        android:text="Ver y Completar"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:visibility="gone"/>
</LinearLayout>