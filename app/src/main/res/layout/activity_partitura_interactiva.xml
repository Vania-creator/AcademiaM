<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F0E8"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp"
        android:layout_marginTop="5dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAtras"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Atrás"
            android:background="#173548"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:elevation="2dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRepetir"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="#D32F2F"
            android:textColor="#FFFFFF"
            android:text="🔄 Repetir"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textAllCaps="false"
            android:visibility="gone"
            android:elevation="2dp"/>

        <TextView
            android:id="@+id/tvTituloCancion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Título de la Canción"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="end"
            android:textColor="#173548"/>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/framePartitura"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:layout_marginBottom="12dp">

        <ImageView
            android:id="@+id/ivPartitura"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/logo"
            android:scaleType="fitXY" />

        <View
            android:id="@+id/viewBarra"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#FF0000" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="5dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSecuenciaNotas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notas: --"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#173548"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tvFeedback"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¡Prepárate!"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"
                    android:layout_marginEnd="16dp"/>

                <TextView
                    android:id="@+id/tvNotaEscuchada"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Escuchando: --"
                    android:textSize="13sp"
                    android:textColor="#64748B"/>
            </LinearLayout>
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnGrabar"
            android:layout_width="160dp"
            android:layout_height="45dp"
            android:text="🔴 Grabar Práctica"
            android:background="#D32F2F"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:elevation="3dp"/>
    </LinearLayout>

</LinearLayout>