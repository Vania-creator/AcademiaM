<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F0E8"
    android:padding="16dp">

    <!-- HEADER: BOTÓN ATRÁS Y TÍTULO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAtras"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Atrás"
            android:background="#173548"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"/>

        <TextView
            android:id="@+id/tvTituloCancion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Título de la Canción"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#173548"/>
    </LinearLayout>

    <!-- CONTENEDOR DE LA IMAGEN Y LA BARRA -->
    <FrameLayout
        android:id="@+id/framePartitura"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/ivPartitura"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/partiturasimple"
            android:scaleType="fitXY" />

        <View
            android:id="@+id/viewBarra"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#FF0000" />

    </FrameLayout>

    <TextView
        android:id="@+id/tvSecuenciaNotas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Notas: --"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="#173548"
        android:layout_marginTop="20dp"/>

    <!-- Este es el texto que dirá ¡Prepárate! -->
    <TextView
        android:id="@+id/tvFeedback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¡Prepárate!"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="#FF9800"
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/tvNotaEscuchada"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Escuchando: --"
        android:textSize="18sp"
        android:gravity="center"
        android:textColor="#64748B"
        android:layout_marginTop="20dp"/>

    <!-- ESPACIO FLEXIBLE (Empuja el botón de grabar hasta abajo) -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- BOTÓN GRABAR -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnGrabar"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="🔴 Grabar Práctica"
        android:background="#D32F2F"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:layout_marginBottom="10dp"/>

</LinearLayout>