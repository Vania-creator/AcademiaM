<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F0E8"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp"
        android:layout_marginTop="5dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAtrasCapas"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Atrás"
            android:background="#173548"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:elevation="2dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Estudio por Capas"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="end"
            android:textColor="#173548"/>

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="👆 Toca dos veces la partitura para revelar la siguiente capa de ayuda"
        android:textAlignment="center"
        android:textColor="#64748B"
        android:textSize="14sp"
        android:textStyle="italic"
        android:layout_marginBottom="10dp"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:layout_marginBottom="10dp">

        <ImageView
            android:id="@+id/ivCapaPartitura"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter" />

    </FrameLayout>

</LinearLayout>