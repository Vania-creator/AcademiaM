<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/card_alumno"
    android:elevation="4dp"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/imgAvatarHorario"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:background="@drawable/circulo_gris"
        android:scaleType="centerCrop"
        android:padding="4dp"
        android:src="@drawable/logo" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtNombreAlumnoH"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre"
                android:textColor="#173548"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/txtInstrumentoH"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="(Batería)"
                android:textColor="#8C837B"
                android:textSize="13sp"
                android:textStyle="italic" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtHoraH"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00 - 00:00"
            android:textColor="#5A4A3F"
            android:textSize="13sp"
            android:layout_marginTop="3dp" />

        <TextView
            android:id="@+id/txtNotasH"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Nota: Sin notas"
            android:textColor="#8C837B"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtTipoClaseH"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fija"
        android:textColor="#B15C2E"
        android:textSize="12sp"
        android:textStyle="bold"
        android:background="@drawable/etiqueta_clase"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp" />

</LinearLayout>