<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#BDBDBD"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true">

    <View
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="@drawable/circulo_gris" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtNombreAlumnoH"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre"
                android:textColor="#222222"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtInstrumentoH"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="(Batería)"
                android:textColor="#173548"
                android:textSize="13sp"
                android:textStyle="italic" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtHoraH"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00 - 00:00"
            android:textColor="#444444"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtNotasH"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Nota: Sin notas"
            android:textColor="#666666"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtTipoClaseH"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fija"
        android:textColor="#555555"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>