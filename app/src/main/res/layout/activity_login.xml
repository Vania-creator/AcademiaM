<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#142F3F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="760dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="45dp"
        android:paddingBottom="35dp">

        <TextView
            android:id="@+id/txtError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Error Al Cargar"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/error_rojo"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- 🔥 LOGO CON ILUMINACIÓN -->
        <FrameLayout
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/glow_logo">

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="250dp"
                android:layout_height="250dp"
                android:layout_gravity="center"
                android:src="@drawable/logo"
                android:scaleType="fitCenter" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="570dp"
            android:maxWidth="350dp"
            android:orientation="vertical"
            android:background="@drawable/tarjeta_login"
            android:elevation="10dp"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="38dp"
            android:paddingBottom="34dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtTitulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Academia de\nMúsica Moncayo"
                    android:textAlignment="center"
                    android:textColor="#142F3F"
                    android:textSize="34sp"
                    android:fontFamily="serif"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="48dp" />

                <EditText
                    android:id="@+id/etUsuario"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Usuario"
                    android:inputType="text"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:textColor="#1E1E1E"
                    android:textColorHint="#777777"
                    android:textSize="16sp"
                    android:singleLine="true"
                    android:background="@drawable/campo_redondo"
                    android:drawableStart="@drawable/ic_usuario"
                    android:drawablePadding="12dp"
                    android:layout_marginBottom="18dp" />

                <EditText
                    android:id="@+id/etContrasena"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:hint="Contraseña"
                    android:inputType="textPassword"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp"
                    android:singleLine="true"
                    android:textColor="#2B2B2B"
                    android:textColorHint="#6F655D"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif"
                    android:background="@drawable/campo_redondo"
                    android:drawableStart="@drawable/ic_candado"
                    android:drawablePadding="14dp"
                    android:layout_marginBottom="44dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:text="Iniciar Sesión"
                    android:textAllCaps="false"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/boton_login"
                    android:backgroundTint="@null"
                    android:elevation="6dp"
                    android:stateListAnimator="@null" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>