<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#163F56"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <Space android:layout_width="match_parent" android:layout_height="24dp" />

        <ImageView
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="@drawable/circulo_blanco"
            android:padding="18dp"
            android:src="@drawable/logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp"
            android:text="Asignar Recompensa"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/fondo_formulario_tarea"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/txtErrorRecompensa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/error_rojo"
                android:gravity="center"
                android:padding="12dp"
                android:text="Faltan datos por llenar"
                android:textColor="#FFFFFF"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Fecha de la Clase"
                android:textColor="#222222"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/btnSeleccionarFechaRec"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/campo_redondo"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:text="Toca para elegir fecha..."
                android:textColor="#222222" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2. Seleccionar Alumno"
                android:textColor="#222222"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/btnSeleccionarAlumnoRec"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/campo_redondo"
                android:backgroundTint="#EEEEEE"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:text="Esperando fecha..."
                android:textColor="#888888" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3. Elige la Insignia a otorgar"
                android:textColor="#222222"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Toca la medalla que el alumno se ganó hoy"
                android:textColor="#173548"
                android:textSize="11sp"
                android:layout_marginBottom="12dp" />

            <GridLayout
                android:id="@+id/gridLayoutInsignias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:layout_marginBottom="24dp"
                android:background="@drawable/campo_redondo"
                android:padding="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnRegresarRec"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/boton_gris"
                    android:text="Cancelar" />
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnAsignarRec"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1.3"
                    android:background="@drawable/boton_gris"
                    android:backgroundTint="#173548"
                    android:text="Dar Insignia"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>