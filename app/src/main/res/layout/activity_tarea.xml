<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#163F56"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <Space
            android:layout_width="match_parent"
            android:layout_height="24dp" />

        <ImageView
            android:id="@+id/imgLogoTarea"
            android:layout_width="165dp"
            android:layout_height="165dp"
            android:background="@drawable/circulo_blanco"
            android:padding="18dp"
            android:scaleType="fitCenter"
            android:src="@drawable/logo"
            android:contentDescription="Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="26dp"
            android:text="Tarea"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="normal" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/fondo_formulario_tarea"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="34dp"
            android:paddingEnd="24dp"
            android:paddingBottom="26dp">

            <TextView
                android:id="@+id/txtErrorTarea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/error_rojo"
                android:gravity="center"
                android:padding="12dp"
                android:text="Completa los campos"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Alumno"
                android:textColor="#222222"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/etAlumnoTarea"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/campo_redondo"
                android:hint=""
                android:inputType="text"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#222222"
                android:textColorHint="#8A8A8A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Titulo"
                android:textColor="#222222"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/etTitulo"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/campo_redondo"
                android:hint=""
                android:inputType="text"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#222222"
                android:textColorHint="#8A8A8A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Notas de Tarea"
                android:textColor="#222222"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="10dp"
                android:text="(Explicacion de como debe de hacer la tarea)"
                android:textColor="#8A8A8A"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etNotasTarea"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="18dp"
                android:background="@drawable/campo_redondo"
                android:hint=""
                android:inputType="text"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#222222"
                android:textColorHint="#8A8A8A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Asignar Gamificacion"
                android:textColor="#222222"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="10dp"
                android:text="Motivacion para el alumno en terminar la tarea"
                android:textColor="#8A8A8A"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="102dp"
                android:layout_marginBottom="28dp"
                android:background="@drawable/campo_redondo"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:id="@+id/icono1"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/circulo_gris"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@android:drawable/btn_star_big_on"
                    android:contentDescription="Icono 1" />

                <ImageView
                    android:id="@+id/icono2"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/circulo_gris"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:contentDescription="Icono 2" />

                <ImageView
                    android:id="@+id/icono3"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/circulo_gris"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@android:drawable/ic_menu_compass"
                    android:contentDescription="Icono 3" />

                <ImageView
                    android:id="@+id/icono4"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/circulo_gris"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@android:drawable/ic_menu_agenda"
                    android:contentDescription="Icono 4" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btnRegresarTarea"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="18dp"
                    android:background="@drawable/boton_gris"
                    android:elevation="4dp"
                    android:text="Regresar"
                    android:textAllCaps="false"
                    android:textColor="#1E1E1E"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnIngresarTarea"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:layout_marginStart="18dp"
                    android:background="@drawable/boton_gris"
                    android:elevation="4dp"
                    android:text="Ingresar"
                    android:textAllCaps="false"
                    android:textColor="#1E1E1E"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>