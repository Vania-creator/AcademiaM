<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F0E8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="225dp"
            android:background="#173548"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="205dp"
                android:layout_height="205dp"
                android:background="@drawable/glow_logo_menu">

                <ImageView
                    android:layout_width="145dp"
                    android:layout_height="145dp"
                    android:layout_gravity="center"
                    android:padding="10dp"
                    android:src="@drawable/logo"
                    android:scaleType="fitCenter" />

            </FrameLayout>

        </LinearLayout>

        <!-- TÍTULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="18dp"
            android:text="Asignar Tarea"
            android:textColor="#173548"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- FORMULARIO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="22dp"
            android:layout_marginEnd="22dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/fondo_formulario_tarea"
            android:orientation="vertical"
            android:padding="24dp"
            android:elevation="3dp">

            <TextView
                android:id="@+id/txtErrorTarea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/error_rojo"
                android:gravity="center"
                android:padding="12dp"
                android:text="Faltan datos por llenar"
                android:textColor="#FFFFFF"
                android:visibility="gone" />

            <!-- FECHA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Fecha de la Clase"
                android:textColor="#173548"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnSeleccionarFechaTarea"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/campo_redondo"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Toca para elegir fecha..."
                android:textColor="#263746" />

            <!-- ALUMNO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2. Seleccionar Alumno"
                android:textColor="#173548"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnSeleccionarAlumnoTarea"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/campo_redondo"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Esperando fecha..."
                android:textColor="#8C837B"
                android:textSize="14sp"
                android:elevation="2dp" />

            <!-- TITULO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Título de la Tarea"
                android:textColor="#173548"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etTitulo"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/campo_redondo"
                android:hint="Ej. Escala de Do Mayor"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#263746"
                android:textColorHint="#9A9A9A"
                android:textSize="14sp" />

            <!-- NOTAS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notas y Explicación"
                android:textColor="#173548"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etNotasTarea"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="18dp"
                android:background="@drawable/campo_redondo"
                android:gravity="top"
                android:padding="14dp"
                android:hint="Explica cómo debe practicar..."
                android:textColor="#263746"
                android:textColorHint="#9A9A9A"
                android:textSize="14sp" />

            <!-- ICONOS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Motivación (Insignia prometida)"
                android:textColor="#173548"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="* Si haces la tarea, el maestro te dará esta insignia"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/campo_redondo"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView android:id="@+id/icono1" android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="8dp" android:background="@drawable/circulo_gris" android:alpha="0.4" android:src="@android:drawable/btn_star_big_on"/>
                <ImageView android:id="@+id/icono2" android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="8dp" android:background="@drawable/circulo_gris" android:alpha="0.4" android:src="@android:drawable/ic_menu_gallery"/>
                <ImageView android:id="@+id/icono3" android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="8dp" android:background="@drawable/circulo_gris" android:alpha="0.4" android:src="@android:drawable/ic_menu_compass"/>
                <ImageView android:id="@+id/icono4" android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="8dp" android:background="@drawable/circulo_gris" android:alpha="0.4" android:src="@android:drawable/ic_menu_agenda"/>

            </LinearLayout>

            <!-- BOTONES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnRegresarTarea"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/boton_menu_animado"
                    android:backgroundTint="@null"
                    android:text="Cancelar"
                    android:textAllCaps="false"
                    android:textColor="#263746"
                    android:textStyle="bold"
                    android:elevation="5dp"
                    android:stateListAnimator="@null" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnIngresarTarea"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1.3"
                    android:background="@drawable/boton_login"
                    android:backgroundTint="@null"
                    android:text="Asignar Tarea"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:elevation="6dp"
                    android:stateListAnimator="@null" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>