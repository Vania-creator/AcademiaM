<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#163F56"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <Space android:layout_width="match_parent" android:layout_height="24dp" />

        <ImageView
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="@drawable/circulo_blanco"
            android:padding="18dp"
            android:src="@drawable/logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp"
            android:text="Asignar Tarea"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/fondo_formulario_tarea"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/txtErrorTarea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/error_rojo"
                android:gravity="center"
                android:padding="12dp"
                android:text="Faltan datos por llenar"
                android:textColor="#FFFFFF"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Fecha de la Clase"
                android:textColor="#222222"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/btnSeleccionarFechaTarea"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/campo_redondo"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:text="Toca para elegir fecha..."
                android:textColor="#222222" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2. Seleccionar Alumno"
                android:textColor="#222222"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/btnSeleccionarAlumnoTarea"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/campo_redondo"
                android:backgroundTint="#EEEEEE"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:text="Esperando fecha..."
                android:textColor="#888888" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Título de la Tarea"
                android:textColor="#222222" />
            <EditText
                android:id="@+id/etTitulo"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/campo_redondo"
                android:hint="Ej. Escala de Do Mayor"
                android:paddingStart="18dp"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notas y Explicación"
                android:textColor="#222222" />
            <EditText
                android:id="@+id/etNotasTarea"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="18dp"
                android:background="@drawable/campo_redondo"
                android:gravity="top"
                android:padding="12dp"
                android:hint="Explica cómo debe practicar..."
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Motivación (Insignia prometida)"
                android:textColor="#222222"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="* Si haces la tarea, el maestro te dará esta insignia"
                android:textColor="#173548"
                android:textSize="11sp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/campo_redondo"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView android:id="@+id/icono1" android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="8dp" android:background="@drawable/circulo_gris" android:alpha="0.4" android:src="@android:drawable/btn_star_big_on" />
                <ImageView android:id="@+id/icono2" android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="8dp" android:background="@drawable/circulo_gris" android:alpha="0.4" android:src="@android:drawable/ic_menu_gallery" />
                <ImageView android:id="@+id/icono3" android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="8dp" android:background="@drawable/circulo_gris" android:alpha="0.4" android:src="@android:drawable/ic_menu_compass" />
                <ImageView android:id="@+id/icono4" android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="8dp" android:background="@drawable/circulo_gris" android:alpha="0.4" android:src="@android:drawable/ic_menu_agenda" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnRegresarTarea"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/boton_gris"
                    android:text="Cancelar" />
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnIngresarTarea"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1.3"
                    android:background="@drawable/boton_gris"
                    android:backgroundTint="#173548"
                    android:text="Asignar Tarea"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>