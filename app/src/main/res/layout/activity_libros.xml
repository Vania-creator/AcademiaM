<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F0E8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="#173548"
        android:gravity="center"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:background="@drawable/glow_logo_menu">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:src="@drawable/logo"
                android:scaleType="fitCenter"
                android:contentDescription="Logo" />

        </FrameLayout>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="24dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selecciona un libro"
                android:textColor="#173548"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Elige el material con el que trabajarás"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="22dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/contenedor_lista_alumnos"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="3dp">

                <LinearLayout
                    android:id="@+id/itemLibro1"
                    android:layout_width="match_parent"
                    android:layout_height="82dp"
                    android:layout_marginBottom="14dp"
                    android:background="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/circulo_gris"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="#173548"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Libro 1: Notas Básicas"
                            android:textColor="#173548"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Piano"
                            android:textColor="#64748B"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:text="›"
                        android:textColor="#173548"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/itemLibro2"
                    android:layout_width="match_parent"
                    android:layout_height="82dp"
                    android:layout_marginBottom="14dp"
                    android:background="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/circulo_gris"
                        android:gravity="center"
                        android:text="2"
                        android:textColor="#173548"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Libro 2: Escala Alta"
                            android:textColor="#173548"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Piano"
                            android:textColor="#64748B"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:text="›"
                        android:textColor="#173548"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/itemLibro3"
                    android:layout_width="match_parent"
                    android:layout_height="82dp"
                    android:layout_marginBottom="14dp"
                    android:background="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/circulo_gris"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="#173548"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Libro 3: Estrellita"
                            android:textColor="#173548"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Piano"
                            android:textColor="#64748B"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:text="›"
                        android:textColor="#173548"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/itemLibro4"
                    android:layout_width="match_parent"
                    android:layout_height="82dp"
                    android:background="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/circulo_gris"
                        android:gravity="center"
                        android:text="4"
                        android:textColor="#173548"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Libro 4: Práctica"
                            android:textColor="#173548"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Piano"
                            android:textColor="#64748B"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:text="›"
                        android:textColor="#173548"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnRegresarLibros"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/boton_menu_animado"
        android:backgroundTint="@null"
        android:text="Regresar"
        android:textAllCaps="false"
        android:textColor="#263746"
        android:textStyle="bold"
        android:elevation="5dp"
        android:stateListAnimator="@null" />

</LinearLayout>