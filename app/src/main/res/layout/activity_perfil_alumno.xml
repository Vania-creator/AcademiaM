<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F3F3F3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="#173548"
            android:gravity="center">
            <ImageView
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:src="@drawable/logo"
                android:contentDescription="Logo" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#E5E5E5"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp">

                <View
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/circulo_gris" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtNombrePerfil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cargando..."
                        android:textColor="#222222"
                        android:textSize="18sp"
                        android:textStyle="bold" />


                    <LinearLayout
                        android:id="@+id/containerHorarios"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/txtTutorPerfil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tutor: N/A"
                        android:textColor="#757575"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtRachaPerfil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 Dias"
                    android:textColor="#E64A19"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Últimas Insignias:"
                android:textColor="#222222"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/containerInsignias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="18dp">
                <View android:layout_width="50dp" android:layout_height="50dp" android:background="@drawable/circulo_gris" android:layout_margin="5dp"/>
                <View android:layout_width="50dp" android:layout_height="50dp" android:background="@drawable/circulo_gris" android:layout_margin="5dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#D8D8D8"
                android:padding="16dp"
                android:layout_marginBottom="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tarea Pendiente:"
                    android:textColor="#222222"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/txtTareaDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No hay tareas asignadas"
                    android:background="#BDBDBD"
                    android:padding="12dp"
                    android:textColor="#222222" />

                <TextView
                    android:id="@+id/txtTareaAsignadaPor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Asignada por: --"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:textColor="#666666" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#D8D8D8"
                android:padding="16dp"
                android:layout_marginBottom="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Último Reporte de Clase:"
                    android:textColor="#222222"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/txtReporteDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sin reportes recientes"
                    android:background="#BDBDBD"
                    android:padding="12dp"
                    android:textColor="#222222" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnRegresarPerfil"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/boton_gris"
                    android:backgroundTint="@null"
                    android:text="Regresar"
                    android:textAllCaps="false"
                    android:textColor="#222222" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnGrabaciones"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/boton_gris"
                    android:backgroundTint="@null"
                    android:text="Grabaciones"
                    android:textAllCaps="false"
                    android:textColor="#222222" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>