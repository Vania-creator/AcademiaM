<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F4F0E8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="#173548"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:background="@drawable/glow_logo_menu">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:src="@drawable/logo"
                    android:scaleType="fitCenter"
                    android:contentDescription="Logo" />

            </FrameLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_alumno"
                android:padding="16dp"
                android:elevation="4dp"
                android:gravity="top"
                android:layout_marginBottom="24dp"
                android:backgroundTint="@null">

                <ImageView
                    android:id="@+id/imgPerfilFoto"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:minWidth="72dp"
                    android:minHeight="72dp"
                    android:background="@drawable/circulo_gris"
                    android:scaleType="centerCrop"
                    android:padding="2dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtNombrePerfil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cargando..."
                        android:textColor="#173548"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtInstrumentoPerfil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Instrumentos"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtHorarioPerfil"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Horarios..."
                        android:textColor="#173548"
                        android:textSize="12sp"
                        android:lineSpacingExtra="2dp" />

                    <TextView
                        android:id="@+id/txtTutorPerfil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Tutor: N/A"
                        android:textColor="#64748B"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtRachaPerfil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 Días"
                    android:textColor="#E64A19"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:paddingStart="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="INSIGNIAS OBTENIDAS"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/txtNivelExpPerfil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nvl 0 • 0 XP"
                    android:textColor="#D89A48"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:id="@+id/containerInsignias"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp" />

            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/contenedor_lista_alumnos"
                android:padding="16dp"
                android:elevation="3dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@null">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="TAREA PENDIENTE"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/btnVerTodasTareas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ver todas ›"
                        android:textColor="#173548"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:padding="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_alumno"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:elevation="2dp"
                    android:backgroundTint="@null">

                    <TextView
                        android:id="@+id/txtStatusTareaPerfil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PENDIENTE"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#B3261E"
                        android:background="@drawable/etiqueta_pendiente"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp" />

                    <TextView
                        android:id="@+id/txtTareaTituloPerfil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Cargando tarea..."
                        android:textColor="#173548"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtTareaDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="No hay tareas asignadas"
                        android:textColor="#64748B"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/contenedor_lista_alumnos"
                android:padding="16dp"
                android:elevation="3dp"
                android:layout_marginBottom="28dp"
                android:backgroundTint="@null">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ÚLTIMO REPORTE DE AVANCE"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/btnVerHistorialReportes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ver historial ›"
                        android:textColor="#173548"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:padding="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_alumno"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:elevation="2dp"
                    android:backgroundTint="@null">

                    <TextView
                        android:id="@+id/txtFechaReportePerfil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fecha: --"
                        android:textSize="12sp"
                        android:textStyle="italic"
                        android:textColor="#64748B" />

                    <TextView
                        android:id="@+id/txtReporteDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="No hay reportes recientes"
                        android:textColor="#173548"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnRegresarPerfil"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/boton_menu_animado"
                    android:backgroundTint="@null"
                    android:text="❮   Regresar"
                    android:textAllCaps="false"
                    android:textColor="#263746"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:elevation="4dp"
                    android:stateListAnimator="@null" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnGrabaciones"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/boton_menu_animado"
                    android:backgroundTint="@null"
                    android:text="🎙️   Grabaciones"
                    android:textAllCaps="false"
                    android:textColor="#263746"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:elevation="4dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>