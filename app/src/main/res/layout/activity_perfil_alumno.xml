<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F4F0E8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="225dp"
            android:background="#173548"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="205dp"
                android:layout_height="205dp"
                android:background="@drawable/glow_logo_menu">

                <ImageView
                    android:layout_width="145dp"
                    android:layout_height="145dp"
                    android:layout_gravity="center"
                    android:src="@drawable/logo"
                    android:scaleType="fitCenter"
                    android:contentDescription="Logo" />

            </FrameLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_alumno"
                android:padding="16dp"
                android:elevation="4dp"
                android:gravity="top"
                android:layout_marginBottom="20dp">

                <View
                    android:id="@+id/imgPerfilFoto"
                    android:layout_width="75dp"
                    android:layout_height="75dp"
                    android:minWidth="75dp"
                    android:minHeight="75dp"
                    android:background="@drawable/circulo_gris" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtNombrePerfil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cargando..."
                        android:textColor="#173548"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/txtInstrumentoPerfil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Instrumentos"
                        android:textColor="#6F655D"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtHorarioPerfil"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Horarios..."
                        android:textColor="#5A4A3F"
                        android:textSize="12sp"
                        android:lineSpacingExtra="2dp" />

                    <TextView
                        android:id="@+id/txtTutorPerfil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Tutor: N/A"
                        android:textColor="#8C837B"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtRachaPerfil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 Días"
                    android:textColor="#B15C2E"
                    android:textStyle="bold"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Últimas Insignias:"
                android:textColor="#173548"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/containerInsignias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/contenedor_lista_alumnos"
                android:padding="16dp"
                android:elevation="3dp"
                android:layout_marginBottom="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tarea Pendiente:"
                        android:textColor="#173548"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnVerTodasTareas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ver todas >"
                        android:textColor="#173548"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:padding="5dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_alumno"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:elevation="2dp">

                    <TextView
                        android:id="@+id/txtStatusTareaPerfil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PENDIENTE"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#B3261E"
                        android:background="@drawable/etiqueta_pendiente"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp" />

                    <TextView
                        android:id="@+id/txtTareaTituloPerfil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Cargando tarea..."
                        android:textColor="#173548"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtTareaDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="No hay tareas asignadas"
                        android:textColor="#5A4A3F"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/contenedor_lista_alumnos"
                android:padding="16dp"
                android:elevation="3dp"
                android:layout_marginBottom="22dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Último Reporte:"
                        android:textColor="#173548"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnVerHistorialReportes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ver historial >"
                        android:textColor="#173548"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:padding="5dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_alumno"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:elevation="2dp">

                    <TextView
                        android:id="@+id/txtFechaReportePerfil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fecha: --"
                        android:textSize="12sp"
                        android:textStyle="italic"
                        android:textColor="#6F655D" />

                    <TextView
                        android:id="@+id/txtReporteDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="No hay reportes recientes"
                        android:textColor="#173548"
                        android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnRegresarPerfil"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/boton_menu_animado"
                    android:backgroundTint="@null"
                    android:text="Regresar"
                    android:textAllCaps="false"
                    android:textColor="#263746"
                    android:textStyle="bold"
                    android:elevation="5dp"
                    android:stateListAnimator="@null" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnGrabaciones"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/boton_menu_animado"
                    android:backgroundTint="@null"
                    android:text="Grabaciones"
                    android:textAllCaps="false"
                    android:textColor="#263746"
                    android:textStyle="bold"
                    android:elevation="5dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>