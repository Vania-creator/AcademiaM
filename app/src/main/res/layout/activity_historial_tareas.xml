<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F0E8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="#173548"
        android:gravity="center"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="@drawable/glow_logo_menu">

            <ImageView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                android:src="@drawable/logo"
                android:scaleType="fitCenter"
                android:contentDescription="Logo"/>

        </FrameLayout>

        <TextView
            android:id="@+id/txtTituloHistorialTareas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tareas de Alumno"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HISTORIAL DE ASIGNACIONES"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="14dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:id="@+id/layoutTareasVacio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/contenedor_lista_alumnos"
                android:padding="32dp"
                android:elevation="3dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@null"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨"
                    android:textSize="36sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¡Todo al día por aquí!"
                    android:textColor="#173548"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No se encontraron tareas pendientes ni archivadas para este alumno."
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/containerTareasList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnRegresarHistorialT"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/boton_menu_animado"
        android:backgroundTint="@null"
        android:text="❮   Regresar al Perfil"
        android:textAllCaps="false"
        android:textColor="#263746"
        android:textStyle="bold"
        android:elevation="4dp"
        android:stateListAnimator="@null"
        android:gravity="center"/>

</LinearLayout>