<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F0E8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:background="#173548"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="210dp"
                android:layout_height="210dp"
                android:background="@drawable/glow_logo_menu">

                <ImageView
                    android:id="@+id/imgLogoSuperiorAl"
                    android:layout_width="145dp"
                    android:layout_height="145dp"
                    android:layout_gravity="center"
                    android:src="@drawable/logo"
                    android:scaleType="fitCenter" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F4F0E8"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="24dp"
            android:paddingEnd="22dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgPerfilAlumno"
                    android:layout_width="78dp"
                    android:layout_height="78dp"
                    android:background="@drawable/circulo_gris"
                    android:padding="18dp"
                    android:scaleType="centerInside"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:tint="#6F655D" />

                <LinearLayout
                    android:layout_marginStart="14dp"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/txtNombreAlumno"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cargando..."
                        android:textColor="#263746"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtRachaAlumno"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Racha: 0 Días 🔥"
                        android:textColor="#E64A19"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/boton_menu_animado"
                android:padding="16dp"
                android:layout_marginBottom="20dp"
                android:elevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mi Última Tarea:"
                        android:textColor="#263746"
                        android:textStyle="bold"
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/btnVerTodasTareasAl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ver todas >"
                        android:textColor="#173548"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/txtStatusTareaMenu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="PENDIENTE"
                    android:textColor="#B71C1C"
                    android:background="#FFCDD2"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:textSize="11sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtTituloTareaMenu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Cargando tarea..."
                    android:textColor="#263746"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtDescTareaMenu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="..."
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnAbrirTarea"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/boton_gris"
                    android:backgroundTint="#173548"
                    android:text="Ver y Completar"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:visibility="gone"/>
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnMiProgreso"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/boton_menu_animado"
                android:backgroundTint="@null"
                android:elevation="5dp"
                android:text="Mi Progreso"
                android:textAllCaps="false"
                android:textColor="#263746"
                android:textSize="17sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSeleccionarLibroAl"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/boton_menu_animado"
                android:backgroundTint="@null"
                android:elevation="5dp"
                android:text="Seleccionar Actividad"
                android:textAllCaps="false"
                android:textColor="#263746"
                android:textSize="17sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnReportesAl"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="22dp"
                android:background="@drawable/boton_menu_animado"
                android:backgroundTint="@null"
                android:elevation="5dp"
                android:text="Mis Reportes"
                android:textAllCaps="false"
                android:textColor="#263746"
                android:textSize="17sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnLogoutAlumno"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/boton_logout"
                android:backgroundTint="@null"
                android:elevation="4dp"
                android:text="Cerrar Sesión"
                android:textAllCaps="false"
                android:textColor="#B3261E"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>