<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F0E8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="#173548"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:background="@drawable/glow_logo_menu">

                <ImageView
                    android:id="@+id/imgLogoSuperiorAl"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:src="@drawable/logo"
                    android:scaleType="fitCenter" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F4F0E8"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingEnd="20dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="#FFFFFF"
                android:elevation="3dp"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:backgroundTint="@null">

                <ImageView
                    android:id="@+id/imgPerfilAlumno"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/circulo_gris"
                    android:padding="3dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_myplaces" />

                <LinearLayout
                    android:layout_marginStart="14dp"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/txtNombreAlumno"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cargando..."
                        android:textColor="#173548"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtRachaAlumno"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Racha: 0 Días 🔥"
                        android:textColor="#E64A19"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/boton_menu_animado"
                android:padding="16dp"
                android:layout_marginBottom="24dp"
                android:elevation="4dp"
                android:backgroundTint="@null">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📝  Tarea Pendiente:"
                        android:textColor="#173548"
                        android:textStyle="bold"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/btnVerTodasTareasAl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ver todas ›"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:padding="4dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/txtStatusTareaMenu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="PENDIENTE"
                    android:textColor="#B71C1C"
                    android:background="#FFCDD2"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textSize="10sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtTituloTareaMenu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Cargando tarea..."
                    android:textColor="#263746"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtDescTareaMenu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="..."
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnAbrirTarea"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/boton_gris"
                    android:backgroundTint="#173548"
                    android:text="Ver y Completar"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:visibility="gone"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MI ESPACIO DE APRENDIZAJE"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnMiProgreso"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/boton_menu_animado"
                android:backgroundTint="@null"
                android:elevation="4dp"
                android:stateListAnimator="@null"
                android:text="🏆   Mi Progreso\n      Mira tu nivel actual, experiencia y medallas"
                android:textAllCaps="false"
                android:textColor="#263746"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSeleccionarLibroAl"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/boton_menu_animado"
                android:backgroundTint="@null"
                android:elevation="4dp"
                android:stateListAnimator="@null"
                android:text="🎹   Actividades Interactivas\n      Toca las partituras y practica con el micrófono"
                android:textAllCaps="false"
                android:textColor="#263746"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnReportesAl"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/boton_menu_animado"
                android:backgroundTint="@null"
                android:elevation="4dp"
                android:stateListAnimator="@null"
                android:text="📊   Mis Reportes\n      Consulta tus bitácoras e historial de clases"
                android:textAllCaps="false"
                android:textColor="#263746"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnLogoutAlumno"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/boton_logout"
                android:backgroundTint="@null"
                android:elevation="2dp"
                android:text="🚪  Cerrar Sesión"
                android:textAllCaps="false"
                android:textColor="#B3261E"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>