<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F0E8">

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnRegresar"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/boton_menu_animado"
        android:backgroundTint="@null"
        android:text="Regresar al Menú"
        android:textAllCaps="false"
        android:textColor="#263746"
        android:textSize="15sp"
        android:textStyle="bold"
        android:elevation="4dp"
        android:stateListAnimator="@null"
        android:gravity="center" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/btnRegresar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="210dp"
                android:background="#173548"
                android:gravity="center"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="170dp"
                    android:layout_height="170dp"
                    android:background="@drawable/glow_logo_menu">

                    <ImageView
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:layout_gravity="center"
                        android:src="@drawable/logo"
                        android:scaleType="fitCenter"
                        android:contentDescription="Logo" />
                </FrameLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="28dp">

                <EditText
                    android:id="@+id/etBuscarAlumno"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/campo_busqueda"
                    android:drawableStart="@android:drawable/ic_menu_search"
                    android:drawablePadding="14dp"
                    android:hint="Buscar alumno por nombre..."
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:inputType="textPersonName"
                    android:textColor="#173548"
                    android:textColorHint="#94a3b8"
                    android:textSize="15sp"
                    android:elevation="3dp"
                    android:layout_marginBottom="24dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LISTA DE ALUMNOS ACTIVOS"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="4dp"/>

                <TextView
                    android:id="@+id/txtSinAlumnos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No tienes aún alumnos registrados"
                    android:textColor="#8C837B"
                    android:textSize="15sp"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/containerAlumnos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/contenedor_lista_alumnos"
                    android:padding="14dp"
                    android:elevation="3dp"
                    android:backgroundTint="@null" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnVerTodosInstrumento"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/boton_menu_animado"
                    android:backgroundTint="@null"
                    android:text="🎹   Ver todos los alumnos por instrumento\n      Agrupa tu lista según su clase asignada"
                    android:textAllCaps="false"
                    android:textColor="#263746"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:elevation="4dp"
                    android:stateListAnimator="@null"
                    android:gravity="start|center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>