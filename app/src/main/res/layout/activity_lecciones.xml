<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F3F3"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="14dp"
            android:text="Maestro - Lecciones"
            android:textColor="#4A4A4A"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:background="#173548"
            android:gravity="center">

            <ImageView
                android:layout_width="190dp"
                android:layout_height="190dp"
                android:background="@drawable/circulo_blanco"
                android:contentDescription="Logo"
                android:padding="16dp"
                android:scaleType="fitCenter"
                android:src="@drawable/logo" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="-2dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/fondo_lecciones_contenedor"
            android:orientation="vertical"
            android:paddingTop="26dp"
            android:paddingBottom="26dp">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center_horizontal"
                android:contentDescription="Icono música"
                android:src="@drawable/ic_lecciones_musica" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="34dp"
                android:layout_marginTop="18dp"
                android:layout_marginEnd="34dp"
                android:background="@drawable/fondo_lista_lecciones"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:id="@+id/itemLeccion1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/item_leccion_fondo"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="78dp"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <View
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/circulo_gris" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Leccion 1"
                            android:textColor="#111111"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cancion tal"
                            android:textColor="#5A5A5A"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/itemLeccion2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/item_leccion_fondo"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="78dp"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <View
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/circulo_gris" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Leccion 2"
                            android:textColor="#111111"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cancion 2"
                            android:textColor="#5A5A5A"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/itemLeccion3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/item_leccion_fondo"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="78dp"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <View
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/circulo_gris" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Leccion 3"
                            android:textColor="#111111"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Otra Cancion"
                            android:textColor="#5A5A5A"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/itemLeccion4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/item_leccion_fondo"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="78dp"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <View
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/circulo_gris" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Leccion 4"
                            android:textColor="#111111"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vive la vida loca"
                            android:textColor="#5A5A5A"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRegresarLecciones"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="40dp"
                android:layout_marginTop="18dp"
                android:layout_marginEnd="40dp"
                android:background="@drawable/boton_gris"
                android:backgroundTint="@null"
                android:text="Regresar"
                android:textAllCaps="false"
                android:textColor="#222222"
                android:textSize="18sp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>