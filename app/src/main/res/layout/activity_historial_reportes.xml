<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F0E8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="#173548"
        android:gravity="center"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="@drawable/glow_logo_menu">

            <ImageView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                android:src="@drawable/logo"
                android:scaleType="fitCenter"
                android:contentDescription="Logo" />
        </FrameLayout>

        <TextView
            android:id="@+id/txtTituloHistorial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Historial de Reportes"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <EditText
        android:id="@+id/etBuscadorReportes"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/campo_busqueda"
        android:hint="🔍 Buscar por fecha, palabra o logro..."
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="#173548"
        android:textColorHint="#94a3b8"
        android:textSize="14sp"
        android:elevation="3dp"
        android:inputType="text" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BITÁCORAS DE SEGUIMIENTO"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="14dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:id="@+id/layoutReportesVacio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/contenedor_lista_alumnos"
                android:padding="32dp"
                android:elevation="3dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@null"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txtVacioIcono"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊"
                    android:textSize="36sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/txtVacioTitulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sin registros"
                    android:textColor="#173548"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtVacioSubtexto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No se encontraron bitácoras cargadas en el historial."
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/containerReportes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnRegresarHistorial"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/boton_menu_animado"
        android:backgroundTint="@null"
        android:text="❮   Cerrar Historial"
        android:textAllCaps="false"
        android:textColor="#263746"
        android:textStyle="bold"
        android:elevation="4dp"
        android:stateListAnimator="@null"
        android:gravity="center" />

</LinearLayout>